{% set bg_color = progress == 100 ? 'bg-success' : 'bg-info' %}
<div class="progress">
    <div class="progress-bar {{ bg_color }}" role="progressbar"
         style="width: {{ progress }}%;"
         aria-valuenow="{{ progress }}"
         aria-valuemin="0" aria-valuemax="100">{{ progress|round }}%
    </div>
</div>
